{
  "name": "eventforge_github",
  "description": "EventForge standalone — build Docker image and deploy ECS service eventforge",
  "source": {
    "type": "GITHUB",
    "location": "https://github.com/LoboForge/EventForge",
    "buildspec": "buildspec.yml",
    "gitCloneDepth": 1
  },
  "artifacts": {
    "type": "NO_ARTIFACTS"
  },
  "environment": {
    "type": "LINUX_CONTAINER",
    "image": "aws/codebuild/amazonlinux-x86_64-standard:6.0",
    "computeType": "BUILD_GENERAL1_SMALL",
    "privilegedMode": true,
    "environmentVariables": [
      { "name": "AWS_DEFAULT_REGION", "value": "us-east-2", "type": "PLAINTEXT" },
      { "name": "AWS_ACCOUNT_ID", "value": "994185520581", "type": "PLAINTEXT" }
    ]
  },
  "serviceRole": "arn:aws:iam::994185520581:role/loboforge-codebuild",
  "timeoutInMinutes": 45,
  "queuedTimeoutInMinutes": 120,
  "logsConfig": {
    "cloudWatchLogs": { "status": "ENABLED" }
  }
}
