<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>EventForge</RootNamespace>
    <AssemblyName>EventForge</AssemblyName>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AWSSDK.S3" Version="3.7.405" />
    <PackageReference Include="AWSSDK.SQS" Version="3.7.400.58" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="8.0.10" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="EventForge.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="EventForge.Tests/**" />
    <Content Remove="EventForge.Tests/**" />
    <EmbeddedResource Remove="EventForge.Tests/**" />
    <None Remove="EventForge.Tests/**" />
  </ItemGroup>

</Project>
