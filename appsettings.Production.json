{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EventForge": {
    "ListenUrl": "http://0.0.0.0:8090",
    "AwsRegion": "us-east-2",
    "SqlitePath": "event-forge.db",
    "LocalArtifactDir": "artifacts",
    "EventRetentionDays": 7,
    "PingIntervalSeconds": 30,
    "LeaseSeconds": 900,
    "FlushIntervalSeconds": 3,
    "MaxConcurrentUploads": 5,
    "ApiKeys": {},
    "WorkerKeys": {},
    "S3": {
      "Enabled": true,
      "Bucket": "forge-queue-994185520581-us-east-2",
      "Key": "event-forge/store.db",
      "Region": "us-east-2",
      "BackupIntervalMinutes": 5,
      "LoadOnStartup": true
    },
    "Artifacts": {
      "Enabled": true,
      "Bucket": "forge-queue-994185520581-us-east-2",
      "Prefix": "event-forge/jobs",
      "Region": "us-east-2"
    }
  }
}
